# Imath package Makevars
CMAKE = @CMAKE@

# Directories
IMATH_DIR = @PACKAGE_BASE_DIR@
INST_DIR = @PACKAGE_BASE_DIR@/inst
LIB_DIR = @PACKAGE_BASE_DIR@/inst/lib/@TARGET_ARCH@
INCLUDE_DIR = @PACKAGE_BASE_DIR@/inst/include
IMATH_LIB = $(LIB_DIR)/libImath-3_2.a
IMATH_RUNTIME_LINK_FLAGS_FILE = $(LIB_DIR)/libimath-runtime-link-flags
ifneq ($(wildcard $(IMATH_RUNTIME_LINK_FLAGS_FILE)),)
  IMATH_RUNTIME_LINK_FLAGS = $(shell cat "$(IMATH_RUNTIME_LINK_FLAGS_FILE)")
else
  IMATH_RUNTIME_LINK_FLAGS =
endif
PKG_CXXFLAGS = @MAKE_CXX_FLAGS@

# Required for linking with static libraries
CXXFLAGS = $(CXXFLAGS) $(CXXPICFLAGS)

@LIB_INCLUDE_ASSIGN@
@LIB_LINK_ASSIGN@

ifeq (@LIB_EXISTS@, TRUE)
  PKG_CPPFLAGS = @MAKE_CXX_STANDARD@ $(LIB_INCLUDE)
  PKG_LIBS     = $(LIB_LINK) -lImath-3_2 $(IMATH_RUNTIME_LINK_FLAGS) $(SAN_LIBS)
else
  # Static libraries we need to link against
  # Note that we're using the version suffix pattern that Imath actually creates
  PKG_CPPFLAGS = @MAKE_CXX_STANDARD@ -I$(INCLUDE_DIR) -I@PACKAGE_BASE_DIR@/include
  PKG_LIBS = -L$(LIB_DIR) -lImath-3_2 $(IMATH_RUNTIME_LINK_FLAGS) $(SAN_LIBS)
endif

# Main target
all: $(OBJECTS)

$(OBJECTS): $(IMATH_LIB)

$(IMATH_LIB):
	cd @PACKAGE_BASE_DIR@/src/Imath/build-cran && @CMAKE@ --build . --config Release && \
	cd @PACKAGE_BASE_DIR@/src/Imath/build-cran && @CMAKE@ --install . --config Release
	cd @PACKAGE_BASE_DIR@ && \
	"$(R_HOME)/bin/Rscript" tools/write-runtime-metadata.R "$(LIB_DIR)"
	cd @PACKAGE_BASE_DIR@ && \
	"$(R_HOME)/bin/Rscript" tools/fix-line-endings.R src/Imath/build-cran/Makefile \
	src/Imath/build-cran/config/Makefile \
	src/Imath/build-cran/src/Imath/Makefile \
	src/Makevars \
	src/Imath/build-cran/CMakeFiles/*/CompilerIdC/CMakeCCompilerId.c \
	src/Imath/build-cran/CMakeFiles/*/CompilerIdCXX/CMakeCXXCompilerId.cpp \
	src/Imath/build-cran/config/ImathConfig.h \
	inst/include/Imath/ImathConfig.h

clean:
	rm -rf @PACKAGE_BASE_DIR@/src/Imath/build-cran && \
	rm -rf @PACKAGE_BASE_DIR@/config.log && \
	rm -rf @PACKAGE_BASE_DIR@/config.status && \
	rm -rf @PACKAGE_BASE_DIR@/autom4te.cache && \
	rm -rf @PACKAGE_BASE_DIR@/configure~ && \
	rm -rf @PACKAGE_BASE_DIR@/tools
